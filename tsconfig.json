{
  "compilerOptions": {
    "target": "ES2025",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2025", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./src/core/*"],
      "@platform/*": ["./src/platform/*"],
      "@renderer/*": ["./src/renderer/*"],
      "@world/*": ["./src/world/*"],
      "@assets/*": ["./src/assets/*"],
      "@debug/*": ["./src/debug/*"]
    },
    "types": [
      "vite/client",
      "@webgpu/types",
      "@types/node",
      "vite-plugin-glsl/ext"
    ]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.worker.ts"]
}
